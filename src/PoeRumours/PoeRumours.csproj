<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- 19041 is the floor for two things we depend on: WDA_EXCLUDEFROMCAPTURE (the overlay must be
         invisible to our own screen capture, or the OCR reads our own text back) and the WinRT OCR
         projection. -->
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>PoeRumours</RootNamespace>
    <AssemblyTitle>PoE Rumours</AssemblyTitle>
    <Description>Atlas overlay for Path of Exile 2 that accumulates an Uncharted Waters tile's full rumour pool across saga toggles and counts its Grand Expeditions.</Description>
    <Version>0.1.0</Version>
    <ApplicationIcon>../../media/app.ico</ApplicationIcon>
  </PropertyGroup>

  <!-- Shipped as a self-contained single file: one .exe next to a data\ folder, no installer, no runtime to
       install first (non-goals). Self-contained costs ~70MB, and that is the right trade — "install .NET 10
       Desktop Runtime first" is a wall most people simply do not climb.
       Trimming stays OFF: WinForms reflects over its own types, and a trimmed build fails at runtime, in a
       dialog, on someone else's machine. -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <DebugType>none</DebugType>
  </PropertyGroup>

  <!-- The same .ico is also embedded, because the tray needs to pick a specific SIZE out of it. Pulling the
       icon off the exe (ExtractAssociatedIcon) always hands back 32px, which Windows then squashes to 16 —
       that is precisely the mush the hand-drawn small entries exist to avoid. -->
  <ItemGroup>
    <EmbeddedResource Include="../../media/app.ico" LogicalName="app.ico" />
  </ItemGroup>

  <!-- The data lives at the repo root (data/), not next to the sources: it is edited by hand, reviewed as
       data, and is the one part of this project a non-programmer would touch. Copied next to the exe at
       build time, flattened into data\ so the loader has one place to look. -->
  <ItemGroup>
    <Content Include="../../data/*.json" LinkBase="data">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PoeRumours.Tests" />
  </ItemGroup>

</Project>
